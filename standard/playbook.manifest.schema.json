{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pacs.dev/schema/v0.1/playbook.manifest.schema.json",
  "title": "PACS Playbook Manifest",
  "description": "Schema for <playbook-id>.pacs.yaml playbook manifests. On-disk format is YAML; parse to JSON before validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pacsVersion",
    "kind",
    "id",
    "packId",
    "version",
    "description",
    "outputs"
  ],
  "properties": {
    "pacsVersion": {
      "type": "string",
      "const": "0.1"
    },
    "kind": {
      "type": "string",
      "const": "playbook"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "playbookReportId": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$"
    },
    "defaultResolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "period": {
          "type": "string",
          "enum": [
            "fullAvailableRange",
            "latestCalendarMonth",
            "requireExplicit"
          ]
        }
      }
    },
    "inputs": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/playbookInput"
      }
    },
    "requires": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowRef"
      }
    },
    "uses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skillUse"
      }
    },
    "overlays": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/overlay"
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": {
          "$ref": "#/$defs/primaryOutput"
        }
      }
    }
  },
  "$defs": {
    "playbookInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "boolean", "number", "integer", "date", "enum"]
        },
        "description": {
          "type": "string"
        },
        "default": true,
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "enum" } },
            "required": ["type"]
          },
          "then": {
            "required": ["values"]
          }
        }
      ]
    },
    "workflowRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow"],
      "properties": {
        "workflow": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "skillUse": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["skill"],
          "properties": {
            "skill": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["skillRef"],
          "properties": {
            "skillRef": {
              "$ref": "#/$defs/skillRef"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["skillLiteral"],
          "properties": {
            "skillLiteral": {
              "$ref": "#/$defs/skillLiteral"
            }
          }
        }
      ]
    },
    "skillRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "uri", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["git", "registry", "url", "local"]
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        }
      }
    },
    "skillLiteral": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "instructions"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "instructions": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "overlay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "kind", "when"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["presentation", "enrichment", "evaluation", "advisory", "policy"]
        },
        "when": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "after": {
          "type": "string",
          "minLength": 1
        },
        "when": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "primaryOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "pathTemplate"],
      "properties": {
        "type": {
          "type": "string",
          "const": "report"
        },
        "pathTemplate": {
          "type": "string",
          "minLength": 1
        },
        "contract": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
