{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pacs.dev/schema/v0.1/pack.manifest.schema.json",
  "title": "PACS Pack Manifest",
  "description": "Schema for pack.pacs.yaml. On-disk format is YAML; parse to JSON before validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pacsVersion",
    "kind",
    "packId",
    "name",
    "version",
    "description",
    "playbooks"
  ],
  "properties": {
    "pacsVersion": {
      "type": "string",
      "const": "0.1"
    },
    "kind": {
      "type": "string",
      "const": "pack"
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "string"
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agentSkills": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inputs": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/packInput"
      }
    },
    "playbooks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    }
  },
  "$defs": {
    "packInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "boolean", "number", "integer", "date", "datastore", "workspace", "enum"]
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "default": true,
        "layoutContract": {
          "type": "string",
          "minLength": 1
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "enum" } },
            "required": ["type"]
          },
          "then": {
            "required": ["values"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "datastore" } },
            "required": ["type"]
          },
          "then": {
            "required": ["layoutContract"]
          }
        }
      ]
    }
  }
}
